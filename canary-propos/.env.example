# Supabase - Project URL and public anon key (safe to expose to browser)
# Source: Supabase Dashboard -> Project Settings -> API -> Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Source: Supabase Dashboard -> Project Settings -> API -> anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role key - SERVER ONLY, never prefix with NEXT_PUBLIC_
# Source: Supabase Dashboard -> Project Settings -> API -> service_role key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Supabase Access Token for CLI (non-interactive db push)
# Source: Supabase Dashboard -> Account -> Access Tokens
SUPABASE_ACCESS_TOKEN=your-access-token-here

# Supabase DB password (for direct DB connection)
# Source: Supabase Dashboard -> Project Settings -> Database -> Connection password
SUPABASE_DB_PASSWORD=your-db-password-here

# Test user credentials (per role - for integration tests)
# Create these users in Supabase Auth before running tests
TEST_MANAGER_EMAIL=test-manager@example.com
TEST_MANAGER_PASSWORD=test-password-here
TEST_TENANT_EMAIL=test-tenant@example.com
TEST_TENANT_PASSWORD=test-password-here
TEST_OWNER_EMAIL=test-owner@example.com
TEST_OWNER_PASSWORD=test-password-here
TEST_VENDOR_EMAIL=test-vendor@example.com
TEST_VENDOR_PASSWORD=test-password-here
TEST_ADMIN_EMAIL=test-admin@example.com
TEST_ADMIN_PASSWORD=test-password-here
